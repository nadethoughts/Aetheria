		{"id":"374c6c600468c6be","fromNode":"4ef37bae99c21c9d","fromSide":"right","toNode":"d1462bc6716bd358","toSide":"top","label":"Coralite is a combination\nof the power of the Pearl\nand the Organic material\nof the corpses"},
