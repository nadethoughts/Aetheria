		{"id":"00d9294e86c6c6fe","fromNode":"e8e2201abcf7a71a","fromSide":"right","toNode":"8f01e34d8960f51d","toSide":"left","label":"Fighting"},
		{"id":"cd9162e5ef219c8e","fromNode":"021e69493c830521","fromSide":"left","toNode":"dc77ca86db4ccc24","toSide":"right","label":"Working for..."},
		{"id":"3ab7dc48c3f35a95","fromNode":"9727124cc0ee0515","fromSide":"bottom","toNode":"0179caa77a03bddd","toSide":"left","label":"RITUAL A\nStormcallers want to Make it to the Pearl\nThey need to remove enough of the Pearlbound to get to the pearl without being attacked.\n\nThey created a storm ritual to mimic the power signature of the pearl to attrack the Pearlbound to it to make a hole for them to make it through the Pearl's defenses."},
